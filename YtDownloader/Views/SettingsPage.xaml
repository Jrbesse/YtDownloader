<Page
    x:Class="YtDownloader.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="32,24" Spacing="24" MaxWidth="600">

            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Dependencies Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Dependencies" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="yt-dlp" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.YtDlpVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="ffmpeg" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FfmpegVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Button
                            Content="Check for Updates"
                            Command="{x:Bind ViewModel.CheckUpdatesCommand}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Preferences Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Preferences" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="16">
                        <ToggleSwitch
                            Header="Show notification when download completes"
                            IsOn="{x:Bind ViewModel.ShowNotifications, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Automatically check for yt-dlp updates on startup"
                            IsOn="{x:Bind ViewModel.AutoCheckUpdates, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Remember last used output folder"
                            IsOn="{x:Bind ViewModel.RememberOutputFolder, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Default folder -->
            <StackPanel Spacing="8">
                <TextBlock Text="Default Download Folder" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.DefaultFolder, Mode=OneWay}" />
                    <Button
                        Grid.Column="1"
                        Content="Browse…"
                        Command="{x:Bind ViewModel.BrowseDefaultFolderCommand}" />
                </Grid>
            </StackPanel>

            <!-- About -->
            <StackPanel Spacing="4">
                <TextBlock Text="About" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="{x:Bind versionValue}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    Text="Powered by yt-dlp and ffmpeg. For personal use only."
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

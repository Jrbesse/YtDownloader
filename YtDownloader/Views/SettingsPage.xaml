<Page
    x:Class="YtDownloader.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="32,24" Spacing="24" MaxWidth="600">

            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Dependencies Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Dependencies" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="yt-dlp" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.YtDlpVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="ffmpeg" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FfmpegVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="ffprobe" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FfprobeVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="AtomicParsley" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.AtomicParsleyVersion, Mode=OneWay}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        </Grid>
                        <Button
                            Content="Check for Updates"
                            Command="{x:Bind ViewModel.CheckUpdatesCommand}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Appearance Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Appearance" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="App theme" />
                            <TextBlock
                                Text="Takes effect immediately and persists across restarts."
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.AvailableThemes}"
                            SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                            MinWidth="120"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Preferences Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Preferences" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="16">
                        <ToggleSwitch
                            Header="Show a notification when a download completes"
                            IsOn="{x:Bind ViewModel.ShowNotifications, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Automatically check for yt-dlp updates on startup"
                            IsOn="{x:Bind ViewModel.AutoCheckUpdates, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Remember last used output folder"
                            IsOn="{x:Bind ViewModel.RememberOutputFolder, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Show storage diagnostics on History page"
                            IsOn="{x:Bind ViewModel.ShowDiagnostics, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Show verbose yt-dlp output during downloads"
                            IsOn="{x:Bind ViewModel.VerboseLogging, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Advanced Mode Card -->
            <StackPanel Spacing="8">
                <TextBlock Text="Advanced Mode" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="10">
                        <ToggleSwitch
                            Header="Enable Advanced Mode"
                            IsOn="{x:Bind ViewModel.IsAdvancedMode, Mode=TwoWay}"
                            OnContent="On" OffContent="Off" />
                        <TextBlock
                            Text="Adds an Advanced page with multi-URL queue, extended formats (MKV, FLAC, OPUS, M4A…), codec control, SponsorBlock, subtitles, custom filename templates, and more."
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- About -->
            <StackPanel Spacing="4">
                <TextBlock Text="About" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="{x:Bind VersionValue}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    Text="Powered by yt-dlp, ffmpeg, and AtomicParsley. For personal use only."
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

<Page
    x:Class="YtDownloader.Views.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="32,24">

            <!-- Page Title -->
            <TextBlock
                Text="Download Video"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- ── URL INPUT ── -->
            <StackPanel Spacing="6">
                <TextBlock Text="YouTube URL" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="UrlTextBox"
                        Grid.Column="0"
                        PlaceholderText="Paste a YouTube link here…"
                        Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        Content="Paste from Clipboard"
                        Command="{x:Bind ViewModel.PasteFromClipboardCommand}"
                        VerticalAlignment="Center" />
                </Grid>
                <TextBlock
                    Text="Supports single videos and full playlists"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Loading spinner shown while fetching preview -->
            <StackPanel
                Orientation="Horizontal"
                Spacing="10"
                Visibility="{x:Bind ViewModel.PreviewLoadingVisibility, Mode=OneWay}">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock
                    Text="Fetching video info…"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- ── PLAYLIST NOTICE ── -->
            <InfoBar
                x:Name="PlaylistInfoBar"
                IsOpen="{x:Bind ViewModel.IsPlaylist, Mode=OneWay}"
                IsClosable="False"
                Severity="Informational"
                Title="Playlist detected"
                Message="{x:Bind ViewModel.PlaylistMessage, Mode=OneWay}" />

            <!-- ── VIDEO PREVIEW ── -->
            <Border
                Visibility="{x:Bind ViewModel.VideoInfoVisibility, Mode=OneWay}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Thumbnail placeholder -->
                    <Border
                        Grid.Column="0"
                        Width="120" Height="68"
                        CornerRadius="6"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Image
                            x:Name="ThumbnailImage"
                            Stretch="UniformToFill" />
                        <!--Source="{x:Bind ViewModel.ThumbnailUrl, Mode=OneWay}"-->

                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.VideoTitle, Mode=OneWay}"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Text="{x:Bind ViewModel.ChannelName, Mode=OneWay}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                Text="·"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.VideoDuration, Mode=OneWay}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── FORMAT SELECTOR ── -->
            <StackPanel Spacing="8">
                <TextBlock Text="Format" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton
                        Content="MP4 (Video)"
                        GroupName="Format"
                        IsChecked="{x:Bind ViewModel.IsMp4Selected, Mode=TwoWay}" />
                    <RadioButton
                        Content="MP3 (Audio only)"
                        GroupName="Format"
                        IsChecked="{x:Bind ViewModel.IsMp3Selected, Mode=TwoWay}" />
                    <RadioButton
                        Content="WebM (Smaller size)"
                        GroupName="Format"
                        IsChecked="{x:Bind ViewModel.IsWebMSelected, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>

            <!-- ── QUALITY SELECTOR ── -->
            <StackPanel
                Spacing="8"
                Visibility="{x:Bind ViewModel.QualityVisibility, Mode=OneWay}">
                <TextBlock Text="Quality" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox
                    ItemsSource="{x:Bind ViewModel.AvailableQualities, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedQuality, Mode=TwoWay}"
                    MinWidth="180" />
            </StackPanel>

            <!-- ── OUTPUT FOLDER ── -->
            <StackPanel Spacing="8">
                <TextBlock Text="Save to" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.OutputFolder, Mode=OneWay}"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        Content="Browse…"
                        Command="{x:Bind ViewModel.BrowseFolderCommand}"
                        VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- ── UPDATE BANNER ── -->
            <InfoBar
                IsOpen="{x:Bind ViewModel.UpdateBannerVisibility, Mode=OneWay}"
                IsClosable="False"
                Severity="Informational"
                Title="{x:Bind ViewModel.UpdateBannerText, Mode=OneWay}" />

            <!-- ── DOWNLOAD / CANCEL BUTTONS ── -->
            <Grid>
                <Button
                    Content="Download"
                    Command="{x:Bind ViewModel.DownloadCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="44"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Visibility="{x:Bind ViewModel.DownloadVisibility, Mode=OneWay}" />
                <Button
                    Content="Cancel Download"
                    Command="{x:Bind ViewModel.CancelDownloadCommand}"
                    HorizontalAlignment="Stretch"
                    Height="44"
                    FontSize="15"
                    Visibility="{x:Bind ViewModel.CancelVisibility, Mode=OneWay}" />
            </Grid>

            <!-- ── PROGRESS ── -->
            <StackPanel
                Spacing="6"
                Visibility="{x:Bind ViewModel.ProgressVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock
                        Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Left" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                </Grid>
                <ProgressBar
                    Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                    Maximum="100"
                    IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}" />
                <TextBlock
                    Text="{x:Bind ViewModel.ProgressDetail, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- ── DONE STATE ── -->
            <StackPanel
                Spacing="12"
                Visibility="{x:Bind ViewModel.DoneVisibility, Mode=OneWay}"
                HorizontalAlignment="Center">
                <TextBlock
                    Text="✅ Download complete!"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                <TextBlock
                    Text="{x:Bind ViewModel.DoneMessage, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button
                        Content="Open Folder"
                        Command="{x:Bind ViewModel.OpenFolderCommand}" />
                    <Button
                        Content="Download Another"
                        Command="{x:Bind ViewModel.ResetCommand}"
                        Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
